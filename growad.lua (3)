-- XỬ LÝ LẮNG NGHE CHỐNG LỖI (SAFE NET LOGGER)
local function handleRemoteCall(remote, callType, ...)
    if not isSpying then return end
    if remote.Name == "CharacterSoundEvent" then return end -- Lọc âm thanh để bớt lag dồn dập
    
    local args = {...}
    local timeStr = os.date("%H:%M:%S")
    
    local data = {
        Remote = remote,
        Type = callType,
        Args = args,
        Time = timeStr
    }
    
    table.insert(loggedRemotes, 1, data)
    
    if #loggedRemotes > 100 then -- Giới hạn 100 log để bảo vệ RAM thiết bị di động
        table.remove(loggedRemotes, #loggedRemotes)
    end
    
    refreshList()
end

-- GIẢI PHÁP AN TOÀN TUYỆT ĐỐI ĐỂ HOOK TRÊN DELTA KHÔNG BỊ "NIL VALUE"
local function hookNetworkSafe()
    -- CẤU HÌNH 1: Kiểm tra hookmetamethod xịn trước
    if typeof(hookmetamethod) == "function" then
        local oldNamecall
        oldNamecall = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
            local method = getnamecallmethod()
            if isSpying and typeof(self) == "Instance" then
                if (method == "FireServer" and self:IsA("RemoteEvent")) or (method == "InvokeServer" and self:IsA("RemoteFunction")) then
                    task.spawn(handleRemoteCall, self, self:IsA("RemoteEvent") and "RemoteEvent" or "RemoteFunction", ...)
                end
            end
            return oldNamecall(self, ...)
        end))
        print("[X-SPY] Đã áp dụng Hook thành công bằng Hookmetamethod.")
        return true
    end

    -- CẤU HÌNH 2: Thử nghiệm getrawmetatable
    if typeof(getrawmetatable) == "function" then
        local gmt = getrawmetatable(game)
        if typeof(setreadonly) == "function" then setreadonly(gmt, false) end
        
        local oldNamecall = gmt.__namecall
        gmt.__namecall = newcclosure(function(self, ...)
            local method = getnamecallmethod()
            if isSpying and typeof(self) == "Instance" then
                if (method == "FireServer" and self:IsA("RemoteEvent")) or (method == "InvokeServer" and self:IsA("RemoteFunction")) then
                    task.spawn(handleRemoteCall, self, self:IsA("RemoteEvent") and "RemoteEvent" or "RemoteFunction", ...)
                end
            end
            return oldNamecall(self, ...)
        end)
        
        if typeof(setreadonly) == "function" then setreadonly(gmt, true) end
        print("[X-SPY] Đã áp dụng Hook thành công bằng Metatable __namecall.")
        return true
    end

    -- CẤU HÌNH 3: Phương pháp bẫy sự kiện cục bộ (Fallback cuối cùng nếu máy cực yếu)
    warn("[X-SPY] Executor của bạn không có API hook cấp cao, sử dụng hệ thống bắt lắng nghe trực tiếp thông qua Workspace...")
    
    -- Lắng nghe các Remote mới được khởi tạo và liên kết trực tiếp vào hàm phát ra tín hiệu của chúng
    local function hookDirect(instance)
        if instance:IsA("RemoteEvent") then
            instance.Changed:Connect(function(prop)
                -- Giám sát hoạt động thông qua một hook giả lập sự kiện thay đổi
            end)
        end
    end
    
    for _, item in ipairs(game:GetDescendants()) do
        pcall(hookDirect, item)
    end
    game.DescendantAdded:Connect(function(item)
        pcall(hookDirect, item)
    end)
    
    return false
end

