-- HÀM CHUYỂN ĐỔI GIÁ TRỊ AN TOÀN
local function formatValue(val)
    local valType = typeof(val)
    if valType == "string" then
        return string.format('"%s"', val)
    elseif valType == "Instance" then
        local ok, path = pcall(function() return val:GetFullName() end)
        return ok and path or '"[Instance bị xoá]"'
    elseif valType == "Vector3" then
        return string.format("Vector3.new(%.2f, %.2f, %.2f)", val.X, val.Y, val.Z)
    elseif valType == "CFrame" then
        return string.format("CFrame.new(%s)", tostring(val))
    elseif valType == "Color3" then
        return string.format("Color3.fromRGB(%d, %d, %d)", val.R*255, val.G*255, val.B*255)
    elseif valType == "table" then
        local success, result = pcall(function() return HttpService:JSONEncode(val) end)
        if success then return result else return "{}" end
    else
        return tostring(val)
    end
end

-- TỰ ĐỘNG TẠO MÃ SCRIPT GỬI REMOTE
local function generateLuaScript(data)
    if not data.Remote or not data.Remote.Parent then
        return "-- LỖI: Đối tượng Remote này đã bị xóa khỏi Game!"
    end
    
    local code = {}
    table.insert(code, string.format("-- Được tạo bởi X-Spy Delta (Thời gian: %s)", data.Time))
    table.insert(code, string.format("local Target = %s", data.Remote:GetFullName()))
    table.insert(code, "")
    table.insert(code, "local args = {")
    for i, arg in ipairs(data.Args) do
        local comma = (i < #data.Args) and "," or ""
        table.insert(code, string.format("    [%d] = %s%s", i, formatValue(arg), comma))
    end
    table.insert(code, "}")
    table.insert(code, "")
    
    if data.Type == "RemoteEvent" then
        table.insert(code, "Target:FireServer(unpack(args))")
    else
        table.insert(code, "local res = Target:InvokeServer(unpack(args))")
        table.insert(code, "print('Kết quả trả về:', res)")
    end
    
    return table.concat(code, "\n")
end

