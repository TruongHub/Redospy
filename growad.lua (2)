-- LOGIC ĐỊNH DẠNG KIỂU DỮ LIỆU
local function formatValue(val)
    local valType = typeof(val)
    if valType == "string" then
        return string.format('"%s"', val)
    elseif valType == "Instance" then
        return val:GetFullName()
    elseif valType == "Vector3" then
        return string.format("Vector3.new(%.3f, %.3f, %.3f)", val.X, val.Y, val.Z)
    elseif valType == "CFrame" then
        return string.format("CFrame.new(%s)", tostring(val))
    elseif valType == "Color3" then
        return string.format("Color3.fromRGB(%d, %d, %d)", val.R*255, val.G*255, val.B*255)
    elseif valType == "table" then
        local success, result = pcall(function()
            return HttpService:JSONEncode(val)
        end)
        if success then return result else return "{}" end
    else
        return tostring(val)
    end
end

-- TẠO SCRIPT LUAU TỰ ĐỘNG
local function generateLuaScript(data)
    local remote = data.Remote
    local args = data.Args
    local isEvent = data.Type == "RemoteEvent"
    
    local code = {}
    table.insert(code, string.format("-- Generated by X-Spy Ultra (Time: %s)", data.Time))
    table.insert(code, string.format("local TargetRemote = %s", remote:GetFullName()))
    table.insert(code, "")
    table.insert(code, "local args = {")
    for i, arg in ipairs(args) do
        local comma = (i < #args) and "," or ""
        table.insert(code, string.format("    [%d] = %s%s", i, formatValue(arg), comma))
    end
    table.insert(code, "}")
    table.insert(code, "")
    
    if isEvent then
        table.insert(code, "TargetRemote:FireServer(unpack(args))")
    else
        table.insert(code, "local response = TargetRemote:InvokeServer(unpack(args))")
        table.insert(code, "print('Response:', response)")
    end
    
    return table.concat(code, "\n")
end

