-- XỬ LÝ LẮNG NGHE SỰ KIỆN MẠNG
local function handleRemoteCall(remote, callType, ...)
    if not isSpying then return end
    
    -- Chống log các dịch vụ hệ thống không cần thiết gây lag
    if remote.Name == "CharacterSoundEvent" or remote.Name == "CharacterSoundEvent" then return end
    
    local args = {...}
    local timeStr = os.date("%H:%M:%S")
    
    local data = {
        Remote = remote,
        Type = callType,
        Args = args,
        Time = timeStr
    }
    
    table.insert(loggedRemotes, 1, data)
    
    -- Giới hạn 150 Log trong RAM để giảm thiểu giật lag game
    if #loggedRemotes > 150 then
        table.remove(loggedRemotes, #loggedRemotes)
    end
    
    refreshList()
end

-- PHƯƠNG PHÁP HOOK MẠNG ULTRA COMPATIBILITY (Tương thích cao)
local function startHook()
    -- Cách 1: Sử dụng hookmetamethod (Tiêu chuẩn của các Executor xịn hiện tại)
    if hookmetamethod then
        local oldNamecall
        oldNamecall = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
            local method = getnamecallmethod()
            if isSpying and typeof(self) == "Instance" then
                if (method == "FireServer" and self:IsA("RemoteEvent")) or (method == "InvokeServer" and self:IsA("RemoteFunction")) then
                    task.spawn(handleRemoteCall, self, self:IsA("RemoteEvent") and "RemoteEvent" or "RemoteFunction", ...)
                end
            end
            return oldNamecall(self, ...)
        end))
        print("[X-SPY] Đã kích hoạt hook bảo mật cao thông qua hookmetamethod.")
    
    -- Cách 2: Sửa đổi trực tiếp Metatable (Dành cho các Executor cơ bản không có hookmetamethod)
    elseif getrawmetatable then
        local gmt = getrawmetatable(game)
        if setreadonly then setreadonly(gmt, false) end
        
        local oldNamecall = gmt.__namecall
        gmt.__namecall = newcclosure(function(self, ...)
            local method = getnamecallmethod()
            if isSpying and typeof(self) == "Instance" then
                if (method == "FireServer" and self:IsA("RemoteEvent")) or (method == "InvokeServer" and self:IsA("RemoteFunction")) then
                    task.spawn(handleRemoteCall, self, self:IsA("RemoteEvent") and "RemoteEvent" or "RemoteFunction", ...)
                end
            end
            return oldNamecall(self, ...)
        end)
        
        if setreadonly then setreadonly(gmt, true) end
        print("[X-SPY] Đã kích hoạt hook dự phòng thông qua Metatable __namecall.")
    else
        warn("[X-SPY] Thất bại! Executor của bạn không hỗ trợ các tính năng Hook cần thiết để theo dõi Remote.")
    end
end

-- Thực thi Hook mạng an toàn
local success, err = pcall(startHook)
if not success then
    warn("[X-SPY ERROR] Không thể hook mạng: " .. tostring(err))
end

